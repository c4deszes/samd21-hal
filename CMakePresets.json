{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "conf-armgcc-default",
            "binaryDir": "${sourceDir}/_build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/tools/cmake/armgcc-toolchain.cmake",
                "SAMD21_HAL_BUILD_TESTS": "ON",
                "SAMD21_HAL_BUILD_DOCS": "ON"
            },
            "hidden": true
        },
        {
            "name": "conf-debug-unix",
            "inherits": "conf-armgcc-default",
            "generator": "Unix Makefiles",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "conf-debug-mingw",
            "inherits": "conf-armgcc-default",
            "generator": "MinGW Makefiles",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-test-targets",
            "targets": [
                "samd21-hal-test"
            ],
            "hidden": true
        },
        {
            "name": "build-docs-targets",
            "targets": ["Sphinx"],
            "hidden": true
        },
        {
            "name": "build-tests-unix",
            "inherits": "build-test-targets",
            "configurePreset": "conf-debug-unix"
        },
        {
            "name": "build-docs-unix",
            "inherits": "build-docs-targets",
            "configurePreset": "conf-debug-unix"
        }
    ],
    "workflowPresets": [
        {
            "name": "workflow-build",
            "steps": [
                {
                    "type": "configure",
                    "name": "conf-debug-unix"
                },
                {
                    "type": "build",
                    "name": "build-test-targets"
                }
            ]
        },
        {
            "name": "workflow-docs",
            "steps": [
                {
                    "type": "configure",
                    "name": "conf-debug-unix"
                },
                {
                    "type": "build",
                    "name": "build-docs-unix"
                }
            ]
        }
    ]
}